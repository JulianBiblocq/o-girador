rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Lecture publique
      allow read: if true;
      
      // Écriture restreinte : authentification requise, taille < 4Mo, et type audio
      allow write: if request.auth != null 
                   && request.resource.size < 4 * 1024 * 1024 
                   && request.resource.contentType.matches('audio/.*');
    }
  }
}
