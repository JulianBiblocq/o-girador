{
  "name": "ogirador",
  "private": true,
  "version": "3.0.1",
  "type": "module",
  "scripts": {
    "predev": "node scripts/updatePresets.js && node scripts/copyAudio.js",
    "dev": "vite --port=3000 --host=0.0.0.0",
    "prebuild": "node scripts/updatePresets.js && node scripts/copyAudio.js",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "deploy": "vite build && npx gh-pages -d dist",
    "deploy-test": "cross-env DEPLOY_ENV=test vite build && npx gh-pages -d dist -e test --add"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^2.4.0",
    "@react-oauth/google": "^0.13.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "gifshot": "^0.4.5",
    "lucide-react": "^0.546.0",
    "lz-string": "^1.5.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tone": "^15.1.22",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/lz-string": "^1.3.34",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.3.0"
  }
}
